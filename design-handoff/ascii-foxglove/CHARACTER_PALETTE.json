  "redModel": {
    "dataDriven": "colors[y][x] === 'r'  → NEVER true for foxglove (grid has only '.' and 'w').",
    "ghostCanvas": "isRed = (x*7 + y*13) % 11 === 0   → deterministic ~9.09% of glyph cells. Color rgba(230,32,46,0.95).",
    "windowCanvas": "hsh = (x*7 + y*13) % 23; red when hsh===0 (~4.35%, #e6202e); hsh<3 → cyan #4fa3c0; hsh<8 → gray #6f7480; else #c6ced8.",
    "landingDOM": "Routes to red <pre> layer only when colors[y][x]==='r'. Since that never occurs, the red layer stays EMPTY and the landing foxglove renders entirely in #e9eaec white.",
    "rule": "Red is deterministic per (x,y) — never randomised per frame (color flicker reads as a glitch). See ascii-motion-doctrine §3."
  },
